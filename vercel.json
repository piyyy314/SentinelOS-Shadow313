{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "shadow313.dev"
        }
      ],
      "destination": "/sentinelos/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "shadow313.com"
        }
      ],
      "destination": "/shadow313/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.shadow313.com"
        }
      ],
      "destination": "/shadow313/$1"
    }
  ]
}
